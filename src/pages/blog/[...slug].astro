---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { byDateDesc, readingTime, relatedPosts } from '../../lib/utils';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

const all = (await getCollection('blog')).sort(byDateDesc);
const idx = all.findIndex((p) => p.id === post.id);
const newer = idx > 0 ? all[idx - 1] : undefined; // sorted desc → previous index is newer
const older = idx < all.length - 1 ? all[idx + 1] : undefined;
const related = relatedPosts(post, all, 2);
const minutes = readingTime(post.body);
---

<BlogPost
	{...post.data}
	ogImage={`/og/${post.id}.png`}
	headings={headings}
	minutes={minutes}
	newer={newer}
	older={older}
	related={related}
>
	<Content />
</BlogPost>
