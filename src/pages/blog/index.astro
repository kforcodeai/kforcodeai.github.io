---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { AUTHOR, SITE_TITLE } from '../../consts';
import { byDateDesc, tagCounts } from '../../lib/utils';

const posts = (await getCollection('blog')).sort(byDateDesc);
const tags = tagCounts(posts);
const description = 'Field notes by Kaushal Prajapati on production AI, agentic systems, evals, retrieval, deep-learning papers, and applied LLM infrastructure.';

const collectionLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Production AI engineering writing by Kaushal Prajapati',
	description,
	url: `${AUTHOR.site}/blog/`,
	author: { '@type': 'Person', name: AUTHOR.name, url: AUTHOR.site },
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${AUTHOR.site}/blog/${post.id}/`,
			name: post.data.title,
		})),
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing on production AI systems · ${SITE_TITLE}`} description={description} ogImage="/og/writing.png" />
		<script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<div class="prompt net"><span>~/kforcode</span>$ ls writing/</div>
				<h1>Writing</h1>
				<p>
					Field notes on production AI, agent runtimes, evaluation, retrieval, and ML systems.
					Written from implementation experience, with the trade-offs left in.
				</p>
			</header>

			<section class="archive" aria-labelledby="archive-title">
				<div class="archive-bar">
					<h2 id="archive-title" class="net">{posts.length} posts</h2>
					<div class="filter" role="group" aria-label="Filter posts by topic">
						<button class="chip chip--plain fbtn active" type="button" data-tag="*">all <span>{posts.length}</span></button>
						{tags.map(({ tag, count }) => <button class="chip fbtn" type="button" data-tag={tag}>{tag} <span>{count}</span></button>)}
					</div>
				</div>
				<div class="post-list">
					{posts.map((post, i) => <div class="cell" data-tags={(post.data.tags ?? []).join(' ')}><PostCard post={post} index={i + 1} variant="row" /></div>)}
				</div>
				<p class="empty net" hidden>No posts match this filter.</p>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				var buttons = document.querySelectorAll('.fbtn');
				var cells = document.querySelectorAll('.cell');
				var empty = document.querySelector('.empty');
				buttons.forEach(function (button) {
					button.addEventListener('click', function () {
						var tag = button.getAttribute('data-tag');
						buttons.forEach(function (item) { item.classList.toggle('active', item === button); });
						var shown = 0;
						cells.forEach(function (cell) {
							var match = tag === '*' || (' ' + cell.getAttribute('data-tags') + ' ').includes(' ' + tag + ' ');
							cell.hidden = !match;
							if (match) shown++;
						});
						if (empty) empty.hidden = shown !== 0;
					});
				});
			})();
		</script>
	</body>
</html>

<style>
	.page-head {
		max-width: 720px;
		padding: 2.5rem 0 3.5rem;
	}

	.prompt {
		margin-bottom: 1rem;
		text-transform: none;
	}

	.prompt span {
		color: var(--accent);
	}

	.page-head h1 {
		font-size: clamp(2.8rem, 6vw, 4.6rem);
	}

	.page-head p {
		margin: 1.1rem 0 0;
		color: var(--muted);
		font-size: 1.02rem;
	}

	.archive-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		margin-bottom: 1rem;
	}

	.archive-bar h2 {
		flex: none;
		color: var(--ink-soft);
	}

	.filter {
		display: flex;
		justify-content: flex-end;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.fbtn {
		cursor: pointer;
	}

	.fbtn span {
		opacity: 0.65;
	}

	.cell[hidden] {
		display: none;
	}

	.empty {
		padding: 2rem 0;
		text-align: center;
	}

	@media (max-width: 700px) {
		.page-head {
			padding-top: 1rem;
		}

		.archive-bar {
			align-items: flex-start;
			flex-direction: column;
		}

		.filter {
			justify-content: flex-start;
		}
	}
</style>
