---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { byDateDesc, tagCounts } from '../../lib/utils';

const posts = (await getCollection('blog')).sort(byDateDesc);
const tags = tagCounts(posts);
const description =
	'Essays on building production AI — agent runtimes, harnesses, evals, MCP developer platforms, RAG, deep-learning papers, and applied LLM engineering by Kaushal Prajapati.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing · ${SITE_TITLE}`} description={description} ogImage="/og/writing.png" />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<span class="net">INDEX::WRITING · {posts.length} POSTS</span>
				<h1>Writing</h1>
				<p class="page-intro">
					Field notes on building production AI — runtimes, agent harnesses, evals, retrieval, and
					applied LLM engineering. No demos; the parts that break at scale.
				</p>
			</header>

			<div class="filter" role="group" aria-label="Filter posts by topic">
				<button class="chip chip--plain fbtn active" data-tag="*">
					all <span class="fcount">{posts.length}</span>
				</button>
				{
					tags.map(({ tag, count }) => (
						<button class="chip fbtn" data-tag={tag}>
							{tag} <span class="fcount">{count}</span>
						</button>
					))
				}
			</div>

			<section class="grid-cards posts">
				{
					posts.map((post, i) => (
						<div class="cell" data-tags={(post.data.tags ?? []).join(' ')}>
							<PostCard post={post} index={i + 1} variant="card" />
						</div>
					))
				}
			</section>
			<p class="empty net" hidden>NO POSTS MATCH THIS FILTER</p>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				var btns = document.querySelectorAll('.fbtn');
				var cells = document.querySelectorAll('.cell');
				var empty = document.querySelector('.empty');
				btns.forEach(function (btn) {
					btn.addEventListener('click', function () {
						var tag = btn.getAttribute('data-tag');
						btns.forEach(function (b) {
							b.classList.toggle('active', b === btn);
						});
						var shown = 0;
						cells.forEach(function (cell) {
							var match = tag === '*' || (' ' + cell.getAttribute('data-tags') + ' ').indexOf(' ' + tag + ' ') !== -1;
							cell.hidden = !match;
							if (match) shown++;
						});
						if (empty) empty.hidden = shown !== 0;
					});
				});
			})();
		</script>

		<style>
			.page-head {
				margin-bottom: 1.75rem;
			}
			.page-head .net {
				color: var(--accent);
			}
			.page-head h1 {
				margin: 0.5rem 0 0.5rem;
			}
			.page-intro {
				color: var(--muted);
				max-width: 40rem;
				margin: 0;
			}
			.filter {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				padding-bottom: 1.75rem;
				margin-bottom: 1.75rem;
				border-bottom: var(--edge) solid var(--line);
			}
			.fbtn {
				cursor: pointer;
			}
			.fbtn.active {
				border-color: var(--accent);
				color: var(--accent);
				background: var(--accent-soft);
			}
			.fcount {
				color: var(--muted);
				margin-left: 0.15em;
			}
			.fbtn.active .fcount {
				color: var(--accent);
			}
			.posts {
				grid-template-columns: repeat(2, 1fr);
			}
			.cell {
				display: block;
			}
			.cell[hidden] {
				display: none;
			}
			.empty {
				text-align: center;
				padding: 2rem 0;
				color: var(--muted);
			}
			@media (max-width: 640px) {
				.posts {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
