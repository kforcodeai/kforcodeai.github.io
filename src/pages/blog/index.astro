---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { AUTHOR, SITE_TITLE, TOPICS } from '../../consts';
import { byDateDesc, tagCounts } from '../../lib/utils';

const posts = (await getCollection('blog')).sort(byDateDesc);
const tags = tagCounts(posts);
const description =
	'Field notes by Kaushal Prajapati on production AI, agentic systems, evals, retrieval, deep-learning papers, and applied LLM infrastructure.';

const collectionLd = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'Production AI engineering writing by Kaushal Prajapati',
	description,
	url: `${AUTHOR.site}/blog/`,
	author: { '@type': 'Person', name: AUTHOR.name, url: AUTHOR.site },
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: posts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${AUTHOR.site}/blog/${post.id}/`,
			name: post.data.title,
		})),
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing on production AI systems · ${SITE_TITLE}`} description={description} ogImage="/og/writing.png" />
		<script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<div class="head-copy">
					<span class="eyebrow">Writing archive · {String(posts.length).padStart(2, '0')} notes</span>
					<h1>Notes from<br />the <em>hard parts.</em></h1>
					<p>
						Long-form explanations of agent runtimes, evaluation systems, retrieval, ML platforms,
						and the papers changing how we build. Written for engineers who want the trade-offs,
						not just the diagram.
					</p>
				</div>
				<aside class="archive-note">
					<span class="net">EDITORIAL SCOPE / 001</span>
					<strong>Research → system → lesson</strong>
					<p>Every note aims to leave you with a model you can use in your own engineering work.</p>
					<ul>
						{TOPICS.slice(0, 4).map((topic) => <li>{topic.label}</li>)}
					</ul>
				</aside>
			</header>

			<section class="archive" aria-labelledby="archive-title">
				<div class="archive-head">
					<div>
						<span class="net">FILTER THE ARCHIVE</span>
						<h2 id="archive-title">All writing</h2>
					</div>
					<div class="filter" role="group" aria-label="Filter posts by topic">
						<button class="chip chip--plain fbtn active" type="button" data-tag="*">
							all <span class="fcount">{posts.length}</span>
						</button>
						{tags.map(({ tag, count }) => (
							<button class="chip fbtn" type="button" data-tag={tag}>
								{tag} <span class="fcount">{count}</span>
							</button>
						))}
					</div>
				</div>

				<div class="post-list">
					{posts.map((post, i) => (
						<div class="cell" data-tags={(post.data.tags ?? []).join(' ')}>
							<PostCard post={post} index={i + 1} variant="row" />
						</div>
					))}
				</div>
				<p class="empty net" hidden>No notes match that filter.</p>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				var btns = document.querySelectorAll('.fbtn');
				var cells = document.querySelectorAll('.cell');
				var empty = document.querySelector('.empty');
				btns.forEach(function (btn) {
					btn.addEventListener('click', function () {
						var tag = btn.getAttribute('data-tag');
						btns.forEach(function (b) { b.classList.toggle('active', b === btn); });
						var shown = 0;
						cells.forEach(function (cell) {
							var value = ' ' + cell.getAttribute('data-tags') + ' ';
							var match = tag === '*' || value.indexOf(' ' + tag + ' ') !== -1;
							cell.hidden = !match;
							if (match) shown++;
						});
						if (empty) empty.hidden = shown !== 0;
					});
				});
			})();
		</script>
	</body>
</html>

<style>
	main {
		padding-top: 4.5rem;
	}

	.page-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 285px;
		gap: clamp(3rem, 8vw, 8rem);
		align-items: end;
		padding-bottom: 4rem;
		border-bottom: 2px solid var(--ink);
	}

	.page-head h1 {
		margin: 1.1rem 0 1.4rem;
		font-size: clamp(4rem, 3rem + 5vw, 7.5rem);
		line-height: 0.88;
	}

	.page-head h1 em {
		color: var(--accent);
		font-family: var(--font-editorial);
		font-weight: 400;
	}

	.head-copy > p {
		max-width: 700px;
		margin: 0;
		color: var(--ink-soft);
		font-family: var(--font-editorial);
		font-size: 1.22rem;
		line-height: 1.55;
	}

	.archive-note {
		padding: 1rem 0 0;
		border-top: 5px solid var(--signal);
	}

	.archive-note > strong {
		display: block;
		margin: 1.2rem 0 0.5rem;
		font-family: var(--font-display);
		font-size: 1.15rem;
	}

	.archive-note p {
		color: var(--muted);
		font-size: 0.85rem;
		line-height: 1.55;
	}

	.archive-note ul {
		list-style: none;
		margin: 1.2rem 0 0;
		padding: 0;
		border-top: var(--edge) solid var(--line);
	}

	.archive-note li {
		padding: 0.42rem 0;
		border-bottom: var(--edge) solid var(--line);
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.archive {
		padding-top: 4rem;
	}

	.archive-head {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 2rem;
		align-items: end;
		padding-bottom: 1.6rem;
	}

	.archive-head h2 {
		margin-top: 0.55rem;
		font-size: 2.65rem;
	}

	.filter {
		display: flex;
		justify-content: flex-end;
		gap: 0.45rem;
		flex-wrap: wrap;
	}

	.fbtn {
		cursor: pointer;
	}

	.fbtn.active {
		color: var(--bg-panel);
		border-color: var(--ink);
		background: var(--ink);
	}

	.fbtn.active::before {
		color: var(--accent);
	}

	.fcount {
		opacity: 0.65;
		margin-left: 0.15em;
	}

	.post-list {
		border-top: 2px solid var(--ink);
	}

	.cell[hidden] {
		display: none;
	}

	.empty {
		padding: 3rem 0;
		text-align: center;
	}

	@media (max-width: 760px) {
		main {
			padding-top: 3rem;
		}

		.page-head {
			grid-template-columns: 1fr;
			gap: 3rem;
			padding-bottom: 3rem;
		}

		.page-head h1 {
			font-size: clamp(3.7rem, 18vw, 5.6rem);
		}

		.archive-head {
			grid-template-columns: 1fr;
		}

		.filter {
			justify-content: flex-start;
		}
	}
</style>
