---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SectionHead from '../components/SectionHead.astro';
import { AUTHOR, PAPERS, SITE_KEYWORDS } from '../consts';

const description = 'Kaushal Prajapati is a Staff AI/ML Engineer with 8+ years building production agent runtimes, evals, retrieval, MCP platforms, and Document AI systems.';

const timeline = [
	{ org: 'HighLevel', role: 'Staff AI/ML Engineer', time: 'now', body: 'Architected the unified AI runtime and agent harness behind six AI product surfaces. The platform carries 15M+ conversations and 800B+ tokens per quarter. Also built a headless developer platform with an MCP server, SDK, CLI, and plugin system exposing 600+ operations.', impact: '6+ products · 99.9% success' },
	{ org: 'Zania AI', role: 'Applied AI Engineer', time: 'previous', body: 'Built Auto Compliance Agents for SOC 2, NIST, HIPAA, and third-party risk. Improved evidence-retrieval F1@10 from 86% to 97% using hybrid retrieval, reranking, citation-span ranking, post-training, and eval release gates.', impact: '86% → 97% F1@10' },
	{ org: 'Intellect AI', role: 'Lead ML Engineer', time: 'previous', body: 'Led commercialization of an Underwriting Copilot. Replaced 23+ document-specific models with one layout-aware extraction architecture and cut AWS Textract spend 70% across 6M+ PDFs.', impact: '23 models → 1 system' },
	{ org: 'First American · Eagle Labs', role: 'R&D Engineer', time: 'earlier', body: 'Built parcel-level risk models that cut title-insurance claims 17%, plus a document-classification framework for 2M+ documents across more than 1,400 classes.', impact: '17% fewer claims' },
];

const toolbox = ['Python', 'TypeScript', 'PyTorch', 'Hugging Face', 'FastAPI', 'Node.js', 'vLLM', 'LoRA / QLoRA / PEFT', 'MCP', 'RAG', 'Evals', 'AWS', 'GCP', 'Azure', 'Docker', 'Kubernetes', 'Postgres', 'Redis', 'OpenSearch'];

const profileLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	name: `About ${AUTHOR.name}`,
	url: `${AUTHOR.site}/about/`,
	mainEntity: {
		'@type': 'Person',
		name: AUTHOR.name,
		alternateName: AUTHOR.handle,
		jobTitle: AUTHOR.role,
		worksFor: { '@type': 'Organization', name: 'HighLevel' },
		knowsAbout: SITE_KEYWORDS,
		sameAs: [AUTHOR.github, AUTHOR.linkedin, ...PAPERS.map((paper) => paper.url)],
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About Kaushal Prajapati · Staff AI/ML Engineer" description={description} ogImage="/og/about.png" />
		<script type="application/ld+json" set:html={JSON.stringify(profileLd)} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<div class="prompt net"><span>~/kforcode</span>$ whoami --verbose</div>
				<h1>Kaushal Prajapati</h1>
				<p class="role">Staff AI/ML Engineer · researcher · writer</p>
				<p class="intro">
					I build the system layer between models and products: agent runtimes, evaluation gates,
					retrieval, memory, model routing, tool authorization, and developer platforms.
				</p>
				<div class="quick-meta">
					<span><i class="dot"></i> HighLevel</span><span>Bengaluru, India</span><span>8+ years</span><span>{PAPERS.length} papers</span>
				</div>
			</header>

			<section class="bio">
				<SectionHead net="about" />
				<div class="two-col">
					<h2>Research depth.<br />Platform instincts.<br />Operator judgment.</h2>
					<div>
						<p>My work sits in the layer most AI demos skip: the infrastructure that makes model behavior reliable, observable, secure, and usable by product teams.</p>
						<p>I care about leverage. A good platform decision makes every product team faster; a good explanation lets other engineers borrow the lesson without paying the same failure cost. That is why I write here.</p>
					</div>
				</div>
			</section>

			<section class="experience">
				<SectionHead net="experience" />
				<ol>
					{timeline.map((item, i) => (
						<li>
							<div class="item-meta net"><span>0{i + 1}</span><span>{item.time}</span></div>
							<div class="item-body">
								<div class="item-head"><div><h3>{item.org}</h3><span>{item.role}</span></div><strong>{item.impact}</strong></div>
								<p>{item.body}</p>
							</div>
						</li>
					))}
				</ol>
			</section>

			<section class="toolkit">
				<SectionHead net="toolkit" />
				<div class="two-col">
					<div><h2>Tools are choices, not identity.</h2><p>I choose for reliability, operability, and team velocity.</p></div>
					<div class="tools">{toolbox.map((tool) => <span class="chip chip--plain">{tool}</span>)}</div>
				</div>
			</section>

			<section class="contact">
				<div><span class="net">open_channel</span><h2>Working on the hard part of AI?</h2><p>I’m open to thoughtful conversations about AI platforms, agent infrastructure, and Staff/Principal engineering work.</p></div>
				<div><a class="btn" href={AUTHOR.linkedin} target="_blank" rel="me noopener">linkedin ↗</a><a class="btn ghost" href={`mailto:${AUTHOR.email}`}>email</a><a class="btn ghost" href={AUTHOR.github} target="_blank" rel="me noopener">github ↗</a></div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	section {
		margin-top: 5rem;
	}

	.page-head {
		max-width: 800px;
		padding: 2.5rem 0 2rem;
	}

	.prompt {
		margin-bottom: 1rem;
		text-transform: none;
	}

	.prompt span,
	.item-meta span:first-child {
		color: var(--accent);
	}

	.page-head h1 {
		font-size: clamp(2.8rem, 6vw, 4.8rem);
	}

	.role {
		margin: 0.6rem 0 0;
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 0.75rem;
	}

	.intro {
		max-width: 760px;
		margin: 1.5rem 0 0;
		color: var(--ink-soft);
		font-size: 1.12rem;
	}

	.quick-meta {
		display: flex;
		gap: 0.65rem 1.2rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.65rem;
	}

	.quick-meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.two-col {
		display: grid;
		grid-template-columns: 0.85fr 1.15fr;
		gap: 5rem;
		align-items: start;
	}

	.two-col h2 {
		font-size: 2rem;
		line-height: 1.2;
	}

	.two-col p {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.experience ol {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.experience li {
		display: grid;
		grid-template-columns: 130px minmax(0, 1fr);
		gap: 2rem;
		padding: 1.6rem 0;
		border-top: 1px solid var(--line);
	}

	.experience li:last-child {
		border-bottom: 1px solid var(--line);
	}

	.item-meta {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		font-size: 0.63rem;
	}

	.item-head {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 1rem;
	}

	.item-head h3 {
		font-size: 1.15rem;
	}

	.item-head div > span {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.64rem;
	}

	.item-head > strong {
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 0.64rem;
		font-weight: 500;
	}

	.item-body > p {
		max-width: 760px;
		margin: 0.8rem 0 0;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.tools {
		display: flex;
		gap: 0.45rem;
		flex-wrap: wrap;
	}

	.contact {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		padding: 1.75rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-panel);
	}

	.contact h2 {
		margin-top: 0.5rem;
		font-size: 1.55rem;
	}

	.contact p {
		max-width: 620px;
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-size: 0.84rem;
	}

	.contact > div:last-child {
		display: flex;
		gap: 0.55rem;
		flex: none;
		flex-wrap: wrap;
	}

	@media (max-width: 720px) {
		.page-head {
			padding-top: 1rem;
		}

		.two-col {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.experience li {
			grid-template-columns: 1fr;
			gap: 0.7rem;
		}

		.item-meta {
			flex-direction: row;
			justify-content: space-between;
		}

		.contact {
			align-items: flex-start;
			flex-direction: column;
		}

		.item-head {
			flex-direction: column;
		}
	}
</style>
