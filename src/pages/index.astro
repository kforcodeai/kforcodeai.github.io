---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import SectionHead from '../components/SectionHead.astro';
import { AUTHOR, PAPERS, SITE_DESCRIPTION, SITE_TITLE, TOPICS } from '../consts';
import { byDateDesc } from '../lib/utils';

const posts = (await getCollection('blog')).sort(byDateDesc);

const homepageLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	name: `${AUTHOR.name} — AI systems engineer and writer`,
	description: SITE_DESCRIPTION,
	url: AUTHOR.site,
	mainEntity: {
		'@type': 'Person',
		name: AUTHOR.name,
		alternateName: AUTHOR.handle,
		jobTitle: AUTHOR.role,
		url: AUTHOR.site,
		sameAs: [AUTHOR.github, AUTHOR.linkedin],
	},
};

const writingLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Latest writing by Kaushal Prajapati',
	itemListElement: posts.slice(0, 5).map((post, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		url: `${AUTHOR.site}/blog/${post.id}/`,
		name: post.data.title,
	})),
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} · Production AI Systems & Research`} description={SITE_DESCRIPTION} ogImage="/og/home.png" />
		<script type="application/ld+json" set:html={JSON.stringify(homepageLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(writingLd)} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="prompt net"><span>kaushal@kforcode</span>:~$ whoami</div>
				<h1>Engineering AI systems that survive production.</h1>
				<p class="lede">
					I’m Kaushal, a Staff AI/ML Engineer. I build agent runtimes, evaluation systems,
					retrieval infrastructure, and developer platforms—and write about what actually works.
				</p>
				<div class="status-line">
					<span><i class="dot"></i> Building at HighLevel</span>
					<span>8+ years in applied AI</span>
					<span>{PAPERS.length} peer-reviewed papers</span>
				</div>
				<div class="hero-actions">
					<a class="btn" href="/blog">read the writing →</a>
					<a class="btn ghost" href="/about">about me</a>
				</div>
			</section>

			<section class="writing">
				<SectionHead net="latest_writing" href="/blog" label="view archive" />
				<div>{posts.slice(0, 4).map((post, i) => <PostCard post={post} index={i + 1} variant="row" />)}</div>
			</section>

			<section class="work">
				<SectionHead net="working_set" />
				<div class="work-grid">
					<div class="work-copy">
						<h2>Systems thinking for applied AI.</h2>
						<p>
							I write for engineers, researchers, and technical leaders working where model behavior
							meets reliability, latency, cost, and product constraints.
						</p>
					</div>
					<nav class="topic-list" aria-label="Writing topics">
						{TOPICS.map((topic) => (
							<a href={topic.slug === 'papers' ? '/research/' : `/tags/${topic.slug}/`}>
								<span>{topic.label}</span><small>{topic.blurb}</small><i>→</i>
							</a>
						))}
					</nav>
				</div>

				<div class="metrics" aria-label="Selected impact">
					<div><strong>15M+</strong><span>conversations / quarter</span></div>
					<div><strong>800B+</strong><span>tokens / quarter</span></div>
					<div><strong>600+</strong><span>MCP operations</span></div>
					<div><strong>99.9%</strong><span>runtime success</span></div>
				</div>
			</section>

			<section class="research">
				<SectionHead net="selected_research" href="/research" label="all papers" />
				<div class="research-grid">
					<div>
						<h2>Research informed by real systems.</h2>
						<p>Peer-reviewed work on Document AI, privacy, clinical summarization, and efficient fine-tuning.</p>
					</div>
					<ol>
						{PAPERS.map((paper, i) => (
							<li><a href={paper.url} target="_blank" rel="noopener"><span class="net">0{i + 1} · {paper.year}</span><strong>{paper.title}</strong><small>{paper.venue} ↗</small></a></li>
						))}
					</ol>
				</div>
			</section>

			<section class="contact">
				<div>
					<span class="net">open_channel</span>
					<h2>Building the hard part of AI?</h2>
					<p>I’m always open to thoughtful conversations about AI platforms, agent infrastructure, and Staff/Principal engineering work.</p>
				</div>
				<div class="contact-links">
					<a class="btn" href={AUTHOR.linkedin} target="_blank" rel="me noopener">linkedin ↗</a>
					<a class="btn ghost" href={`mailto:${AUTHOR.email}`}>email</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	section {
		margin-bottom: 6rem;
	}

	.hero {
		max-width: 850px;
		padding: 4rem 0 2rem;
	}

	.prompt {
		margin-bottom: 1.4rem;
		text-transform: none;
	}

	.prompt span {
		color: var(--accent);
	}

	.hero h1 {
		max-width: 820px;
		font-size: clamp(3.2rem, 7vw, 5.6rem);
		line-height: 1.02;
	}

	.lede {
		max-width: 730px;
		margin: 1.5rem 0 0;
		color: var(--ink-soft);
		font-size: 1.2rem;
		line-height: 1.65;
	}

	.status-line {
		display: flex;
		gap: 0.7rem 1.2rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.66rem;
	}

	.status-line span {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.hero-actions,
	.contact-links {
		display: flex;
		gap: 0.65rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.work-grid,
	.research-grid {
		display: grid;
		grid-template-columns: 0.75fr 1.25fr;
		gap: 5rem;
		align-items: start;
	}

	.work-copy p,
	.research-grid > div p {
		margin-top: 1rem;
		color: var(--muted);
		font-size: 0.94rem;
	}

	.topic-list {
		border-top: 1px solid var(--line);
	}

	.topic-list a {
		display: grid;
		grid-template-columns: 170px 1fr auto;
		gap: 1rem;
		align-items: center;
		padding: 0.9rem 0;
		border-bottom: 1px solid var(--line);
		color: var(--ink);
		text-decoration: none;
	}

	.topic-list a:hover span,
	.topic-list a:hover i {
		color: var(--accent);
	}

	.topic-list span {
		font-size: 0.86rem;
		font-weight: 600;
	}

	.topic-list small {
		color: var(--muted);
		font-size: 0.74rem;
	}

	.topic-list i {
		color: var(--muted);
		font-family: var(--font-mono);
		font-style: normal;
	}

	.metrics {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		margin-top: 3rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
	}

	.metrics div {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 1.15rem;
		border-right: 1px solid var(--line);
	}

	.metrics div:last-child {
		border-right: 0;
	}

	.metrics strong {
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 1.25rem;
	}

	.metrics span {
		color: var(--muted);
		font-size: 0.7rem;
	}

	.research ol {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--line);
	}

	.research li {
		border-bottom: 1px solid var(--line);
	}

	.research li a {
		display: grid;
		gap: 0.25rem;
		padding: 0.9rem 0;
		color: var(--ink);
		text-decoration: none;
	}

	.research li a:hover strong {
		color: var(--accent);
	}

	.research li strong {
		font-size: 0.9rem;
		line-height: 1.4;
	}

	.research li small {
		color: var(--muted);
		font-size: 0.68rem;
	}

	.contact {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 3rem;
		padding: 2rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-panel);
	}

	.contact h2 {
		margin-top: 0.55rem;
		font-size: 1.7rem;
	}

	.contact p {
		max-width: 650px;
		margin: 0.65rem 0 0;
		color: var(--muted);
		font-size: 0.86rem;
	}

	.contact-links {
		flex: none;
		margin-top: 0;
	}

	@media (max-width: 760px) {
		section {
			margin-bottom: 4.5rem;
		}

		.hero {
			padding-top: 2rem;
		}

		.hero h1 {
			font-size: clamp(2.8rem, 13vw, 4rem);
		}

		.work-grid,
		.research-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.metrics {
			grid-template-columns: repeat(2, 1fr);
		}

		.metrics div:nth-child(2) {
			border-right: 0;
		}

		.metrics div:nth-child(-n + 2) {
			border-bottom: 1px solid var(--line);
		}

		.contact {
			align-items: flex-start;
			flex-direction: column;
		}
	}

	@media (max-width: 520px) {
		.topic-list a {
			grid-template-columns: 1fr auto;
		}

		.topic-list small {
			display: none;
		}
	}
</style>
