---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import SectionHead from '../components/SectionHead.astro';
import { AUTHOR, PAPERS, SITE_DESCRIPTION, SITE_TITLE, TOPICS } from '../consts';
import { byDateDesc, readingTime } from '../lib/utils';

const posts = (await getCollection('blog')).sort(byDateDesc);
const featured = posts[0];
const latest = posts.slice(1, 3);

const homepageLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	name: `${AUTHOR.name} — AI systems engineer and writer`,
	description: SITE_DESCRIPTION,
	url: AUTHOR.site,
	dateModified: new Date().toISOString().slice(0, 10),
	mainEntity: {
		'@type': 'Person',
		name: AUTHOR.name,
		alternateName: AUTHOR.handle,
		jobTitle: AUTHOR.role,
		url: AUTHOR.site,
		sameAs: [AUTHOR.github, AUTHOR.linkedin],
	},
};

const writingLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Latest writing by Kaushal Prajapati',
	itemListElement: posts.slice(0, 5).map((post, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		url: `${AUTHOR.site}/blog/${post.id}/`,
		name: post.data.title,
	})),
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} · Production AI Systems & Research`}
			description={SITE_DESCRIPTION}
			ogImage="/og/home.png"
		/>
		<script type="application/ld+json" set:html={JSON.stringify(homepageLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(writingLd)} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-main">
					<span class="eyebrow">Field notes from the system layer</span>
					<h1 id="hero-title">Engineering<br /><em>intelligence,</em><br />in public.</h1>
					<p class="hero-dek">
						I’m Kaushal. I write from the messy boundary between <strong>AI research</strong> and
						<strong>software that has to work</strong>—agentic systems, deep-learning papers,
						evals, retrieval, and the engineering decisions hidden behind reliable AI products.
					</p>
					<div class="hero-actions">
						<a class="btn" href={featured ? `/blog/${featured.id}/` : '/blog'}>Read the latest note <span>→</span></a>
						<a class="text-link" href="/blog">Browse all writing <span>↗</span></a>
					</div>
				</div>

				<aside class="hero-rail" aria-label="About the author">
					<div class="rail-top">
						<span class="net">AUTHOR / 001</span>
						<span class="rail-k">K</span>
					</div>
					<div class="rail-copy">
						<h2>{AUTHOR.name}</h2>
						<p>{AUTHOR.role} building the shared runtime behind production AI at HighLevel.</p>
					</div>
					<dl class="rail-facts">
						<div><dt>Experience</dt><dd>8+ years</dd></div>
						<div><dt>Research</dt><dd>{PAPERS.length} papers</dd></div>
						<div><dt>Focus</dt><dd>AI platforms</dd></div>
					</dl>
					<a class="rail-link" href="/about">Full profile <span>→</span></a>
				</aside>
			</section>

			<section class="dispatches" aria-labelledby="dispatches-title">
				<div class="issue-head">
					<div>
						<span class="net">LATEST DISPATCHES · {String(posts.length).padStart(2, '0')}</span>
						<h2 id="dispatches-title">Ideas worth carrying into your next build.</h2>
					</div>
					<span class="issue-no" aria-hidden="true">/01</span>
				</div>

				{
					featured && (
						<article class="featured node">
							<div class="feature-copy">
								<div class="feature-meta net">
									<span>FEATURED NOTE</span>
									<span><FormattedDate date={featured.data.pubDate} /> · {readingTime(featured.body)} MIN</span>
								</div>
								<h3><a href={`/blog/${featured.id}/`}>{featured.data.title}</a></h3>
								<p>{featured.data.description}</p>
								<div class="feature-foot">
									<div class="feature-tags">
										{(featured.data.tags ?? []).slice(0, 3).map((tag) => <a class="chip" href={`/tags/${tag}/`}>{tag}</a>)}
									</div>
									<a class="read-link" href={`/blog/${featured.id}/`} aria-label={`Read ${featured.data.title}`}>Read note <span>↗</span></a>
								</div>
							</div>

							<div class="runtime-figure" role="img" aria-label="An annotated agent runtime trace from request to evaluated response">
								<div class="trace-head net"><span>RUNTIME TRACE</span><span>STATUS: PASS</span></div>
								<div class="trace-canvas">
									<span class="trace-label label-in net">REQUEST / 00</span>
									<div class="trace-line" aria-hidden="true"><i></i><i></i><i></i></div>
									<div class="runtime-core">
										<small>EXECUTION LAYER</small>
										<strong>AGENT<br />RUNTIME</strong>
										<span>route · act · observe</span>
									</div>
									<div class="orbit orbit-a"><b>A1</b><span>tools</span></div>
									<div class="orbit orbit-b"><b>A2</b><span>memory</span></div>
									<div class="orbit orbit-c"><b>A3</b><span>evals</span></div>
									<span class="trace-label label-out net">RESPONSE / 99.9%</span>
								</div>
								<div class="trace-foot net"><span>15M+ CONVERSATIONS / QTR</span><span>800B+ TOKENS</span></div>
							</div>
						</article>
					)
				}

				<div class="dispatch-grid">
					{latest.map((post, i) => <PostCard post={post} index={i + 2} variant="card" />)}
				</div>
			</section>

			<section class="working-set" aria-labelledby="working-set-title">
				<SectionHead net="THE WORKING SET / 02" href="/blog" label="Explore archive" />
				<div class="working-intro">
					<h2 id="working-set-title">Follow a line of inquiry.</h2>
					<p>
						Not hot takes. Connected notes that move from first principles to production trade-offs,
						with enough detail to be useful at a whiteboard or in a design review.
					</p>
				</div>
				<div class="topic-index">
					{
						TOPICS.map((topic, i) => (
							<a href={topic.slug === 'papers' ? '/research/' : `/tags/${topic.slug}/`} class="topic-row">
								<span class="topic-no net">{String(i + 1).padStart(2, '0')}</span>
								<strong>{topic.label}</strong>
								<span class="topic-blurb">{topic.blurb}</span>
								<span class="topic-arrow">↗</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="proof" aria-labelledby="proof-title">
				<div class="proof-copy">
					<span class="proof-kicker net">THE WORK BEHIND THE WORDS / 03</span>
					<h2 id="proof-title">I write about systems I’ve had to keep alive.</h2>
					<p>
						At HighLevel, Zania, and Intellect, I’ve built agent runtimes, compliance agents,
						retrieval systems, and Document AI platforms. The writing here turns those operating
						lessons into reusable engineering judgment.
					</p>
					<div class="proof-actions">
						<a class="btn proof-btn" href="/about">See experience →</a>
						<a href={AUTHOR.linkedin} target="_blank" rel="me noopener">LinkedIn ↗</a>
					</div>
				</div>
				<div class="proof-metrics" aria-label="Career impact">
					<div><strong>800B+</strong><span>tokens / quarter</span><small>on the shared AI runtime</small></div>
					<div><strong>600+</strong><span>platform operations</span><small>exposed through MCP</small></div>
					<div><strong>97%</strong><span>evidence F1@10</span><small>for compliance retrieval</small></div>
					<div><strong>70%</strong><span>lower OCR spend</span><small>across 6M+ PDFs</small></div>
				</div>
			</section>

			<section class="research" aria-labelledby="research-title">
				<SectionHead net="PEER REVIEW / 04" href="/research" label="All publications" />
				<div class="research-grid">
					<div class="research-intro">
						<span class="paper-count">{String(PAPERS.length).padStart(2, '0')}</span>
						<h2 id="research-title">Research, with the implementation scars included.</h2>
						<p>Published at EMNLP and Elsevier Applied Soft Computing on Document AI, de-identification, and efficient fine-tuning.</p>
					</div>
					<ol class="paper-list">
						{PAPERS.map((paper, i) => (
							<li>
								<a href={paper.url} target="_blank" rel="noopener">
									<span class="net">P{String(i + 1).padStart(2, '0')} · {paper.year}</span>
									<strong>{paper.title}</strong>
									<small>{paper.venue} ↗</small>
								</a>
							</li>
						))}
					</ol>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding-top: 3.25rem;
	}

	section {
		margin-bottom: 7rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 290px;
		gap: clamp(2rem, 7vw, 7.5rem);
		align-items: end;
		min-height: 610px;
		padding: 2.5rem 0 4.2rem;
		border-bottom: 2px solid var(--ink);
	}

	.hero-main {
		max-width: 830px;
	}

	.hero h1 {
		margin: 1.25rem 0 1.65rem;
		font-size: clamp(4.3rem, 3rem + 5.9vw, 8.25rem);
		line-height: 0.84;
		text-wrap: balance;
	}

	.hero h1 em {
		color: var(--accent);
		font-family: var(--font-editorial);
		font-weight: 400;
		letter-spacing: -0.055em;
	}

	.hero-dek {
		max-width: 710px;
		margin: 0;
		color: var(--ink-soft);
		font-family: var(--font-editorial);
		font-size: clamp(1.2rem, 1rem + 0.65vw, 1.5rem);
		line-height: 1.5;
	}

	.hero-actions,
	.proof-actions {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.text-link,
	.read-link,
	.rail-link {
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 650;
		letter-spacing: 0.05em;
		text-decoration: underline;
		text-decoration-color: var(--accent);
		text-transform: uppercase;
	}

	.text-link:hover,
	.read-link:hover,
	.rail-link:hover {
		color: var(--accent);
	}

	.hero-rail {
		position: relative;
		border-top: 6px solid var(--signal);
		border-bottom: var(--edge) solid var(--line-strong);
	}

	.rail-top {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		min-height: 102px;
		padding-top: 0.9rem;
	}

	.rail-k {
		color: var(--accent);
		font-family: var(--font-display);
		font-size: 5.5rem;
		font-weight: 800;
		line-height: 0.72;
		letter-spacing: -0.1em;
	}

	.rail-copy h2 {
		font-size: 1.45rem;
		letter-spacing: -0.04em;
	}

	.rail-copy p {
		color: var(--muted);
		font-size: 0.87rem;
		line-height: 1.55;
	}

	.rail-facts {
		margin: 1.25rem 0;
		border-top: var(--edge) solid var(--line);
	}

	.rail-facts div {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.5rem 0;
		border-bottom: var(--edge) solid var(--line);
		font-family: var(--font-mono);
		font-size: 0.64rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.rail-facts dt {
		color: var(--muted);
	}

	.rail-facts dd {
		margin: 0;
		color: var(--ink);
		font-weight: 650;
	}

	.rail-link {
		display: inline-block;
		margin-bottom: 1.25rem;
	}

	.issue-head {
		display: grid;
		grid-template-columns: minmax(0, 780px) auto;
		justify-content: space-between;
		gap: 2rem;
		align-items: end;
		margin-bottom: 2rem;
	}

	.issue-head h2 {
		margin-top: 0.65rem;
	}

	.issue-no {
		color: var(--accent);
		font-family: var(--font-display);
		font-size: clamp(4rem, 7vw, 7rem);
		font-weight: 750;
		line-height: 0.8;
		letter-spacing: -0.08em;
	}

	.featured {
		display: grid;
		grid-template-columns: 1.08fr 0.92fr;
		min-height: 470px;
		margin-bottom: 1rem;
		overflow: hidden;
	}

	.feature-copy {
		display: flex;
		flex-direction: column;
		padding: clamp(1.5rem, 4vw, 3.2rem);
	}

	.feature-meta {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 3rem;
		color: var(--accent);
	}

	.feature-copy h3 {
		max-width: 650px;
		font-size: clamp(2rem, 1.55rem + 2vw, 3.6rem);
		line-height: 1.02;
	}

	.feature-copy h3 a {
		color: var(--ink);
		text-decoration: none;
	}

	.feature-copy h3 a:hover {
		color: var(--accent);
	}

	.feature-copy > p {
		max-width: 610px;
		margin-top: 0.8rem;
		color: var(--muted);
		font-family: var(--font-editorial);
		font-size: 1.12rem;
		line-height: 1.58;
	}

	.feature-foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: auto;
		padding-top: 2rem;
	}

	.feature-tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.runtime-figure {
		display: grid;
		grid-template-rows: auto 1fr auto;
		min-height: 100%;
		border-left: var(--edge) solid var(--line-strong);
		background: #1b1a17;
		color: #f7f1e8;
	}

	.trace-head,
	.trace-foot {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.75rem 1rem;
		color: #aaa397;
		border-color: #454139;
	}

	.trace-head {
		border-bottom: 1px solid #454139;
	}

	.trace-head span:last-child {
		color: #74dfb1;
	}

	.trace-foot {
		border-top: 1px solid #454139;
		font-size: 0.56rem;
	}

	.trace-canvas {
		position: relative;
		min-height: 365px;
		overflow: hidden;
		background-image:
			linear-gradient(rgba(255,255,255,0.055) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.055) 1px, transparent 1px);
		background-size: 24px 24px;
	}

	.trace-canvas::before,
	.trace-canvas::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 50%;
		border: 1px solid rgba(255, 118, 82, 0.5);
		border-radius: 50%;
		transform: translate(-50%, -50%);
	}

	.trace-canvas::before {
		width: 280px;
		height: 280px;
	}

	.trace-canvas::after {
		width: 350px;
		height: 350px;
		border-style: dashed;
		border-color: rgba(130, 151, 255, 0.35);
	}

	.runtime-core {
		position: absolute;
		z-index: 2;
		left: 50%;
		top: 50%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 172px;
		height: 172px;
		border: 2px solid #ff7652;
		border-radius: 50%;
		background: #1b1a17;
		text-align: center;
		transform: translate(-50%, -50%);
		box-shadow: 0 0 0 8px rgba(255, 118, 82, 0.08);
	}

	.runtime-core small,
	.runtime-core span {
		font-family: var(--font-mono);
		font-size: 0.5rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.runtime-core small {
		color: #ff7652;
	}

	.runtime-core strong {
		margin: 0.5rem 0;
		color: #f7f1e8;
		font-family: var(--font-display);
		font-size: 1.2rem;
		line-height: 0.95;
	}

	.runtime-core span {
		color: #aaa397;
	}

	.orbit {
		position: absolute;
		z-index: 3;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.32rem 0.48rem;
		border: 1px solid #555046;
		background: #1b1a17;
		font-family: var(--font-mono);
		font-size: 0.58rem;
		text-transform: uppercase;
	}

	.orbit b {
		color: #8297ff;
	}

	.orbit span {
		color: #aaa397;
	}

	.orbit-a { left: 9%; top: 28%; }
	.orbit-b { right: 6%; top: 22%; }
	.orbit-c { right: 7%; bottom: 18%; }

	.trace-label {
		position: absolute;
		z-index: 2;
		color: #aaa397;
		font-size: 0.5rem;
	}

	.label-in { left: 1rem; bottom: 1rem; }
	.label-out { right: 1rem; top: 1rem; color: #74dfb1; }

	.trace-line {
		position: absolute;
		z-index: 1;
		left: 8%;
		right: 8%;
		top: 50%;
		height: 1px;
		background: #625d53;
	}

	.trace-line i {
		position: absolute;
		top: -3px;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #ff7652;
	}

	.trace-line i:nth-child(1) { left: 0; }
	.trace-line i:nth-child(2) { left: 50%; }
	.trace-line i:nth-child(3) { right: 0; background: #74dfb1; }

	.dispatch-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.working-set {
		padding-top: 0.25rem;
	}

	.working-intro {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 390px;
		gap: 4rem;
		align-items: end;
		margin: 2.5rem 0 3rem;
	}

	.working-intro p {
		margin: 0;
		color: var(--muted);
		font-family: var(--font-editorial);
		font-size: 1.08rem;
		line-height: 1.55;
	}

	.topic-index {
		border-top: 2px solid var(--ink);
	}

	.topic-row {
		display: grid;
		grid-template-columns: 55px minmax(190px, 0.75fr) 1.4fr auto;
		gap: 1.5rem;
		align-items: center;
		padding: 1.25rem 0;
		border-bottom: var(--edge) solid var(--line-strong);
		color: var(--ink);
		text-decoration: none;
		transition: all 0.18s var(--ease);
	}

	.topic-row:hover {
		padding-left: 0.7rem;
		color: var(--accent);
		background: var(--accent-soft);
	}

	.topic-no {
		color: var(--accent);
	}

	.topic-row strong {
		font-family: var(--font-display);
		font-size: 1.05rem;
	}

	.topic-blurb {
		color: var(--muted);
		font-size: 0.87rem;
	}

	.topic-arrow {
		font-size: 1.15rem;
	}

	.proof {
		display: grid;
		grid-template-columns: 1.08fr 0.92fr;
		gap: 5rem;
		padding: clamp(2rem, 5vw, 4.5rem);
		background: #171611;
		color: #f4efe5;
	}

	.proof-kicker {
		color: #ff7652;
	}

	.proof h2 {
		margin: 1rem 0 1.2rem;
		color: #f4efe5;
	}

	.proof-copy > p {
		max-width: 570px;
		color: #bdb6aa;
		font-family: var(--font-editorial);
		font-size: 1.14rem;
		line-height: 1.58;
	}

	.proof-actions > a:not(.btn) {
		color: #f4efe5;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 650;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.proof-btn {
		color: #171611;
		background: #f4efe5;
		border-color: #f4efe5;
	}

	.proof-metrics {
		border-top: 1px solid #4a463f;
	}

	.proof-metrics div {
		display: grid;
		grid-template-columns: 125px 1fr;
		gap: 0 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid #4a463f;
	}

	.proof-metrics strong {
		grid-row: span 2;
		color: #ff7652;
		font-family: var(--font-display);
		font-size: 2rem;
		letter-spacing: -0.04em;
	}

	.proof-metrics span {
		align-self: end;
		color: #f4efe5;
		font-size: 0.82rem;
		font-weight: 650;
	}

	.proof-metrics small {
		color: #8f897e;
		font-family: var(--font-mono);
		font-size: 0.58rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.research {
		margin-bottom: 1rem;
	}

	.research-grid {
		display: grid;
		grid-template-columns: 0.82fr 1.18fr;
		gap: 5rem;
		align-items: start;
	}

	.paper-count {
		display: block;
		margin-bottom: -0.7rem;
		color: var(--accent);
		font-family: var(--font-display);
		font-size: 6rem;
		font-weight: 750;
		line-height: 1;
		letter-spacing: -0.08em;
	}

	.research-intro h2 {
