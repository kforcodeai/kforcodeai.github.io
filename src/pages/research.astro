---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR, PAPERS, SITE_TITLE } from '../consts';

const description = 'Peer-reviewed AI research by Kaushal Prajapati on Document AI, privacy, clinical summarization, LoRA, DoRA, and parameter-efficient fine-tuning.';
const papersLd = PAPERS.map((paper) => ({
	'@context': 'https://schema.org',
	'@type': 'ScholarlyArticle',
	headline: paper.title,
	name: paper.title,
	abstract: paper.abstract,
	datePublished: String(paper.year),
	url: paper.url,
	author: { '@type': 'Person', name: AUTHOR.name, url: AUTHOR.site },
	publisher: { '@type': 'Organization', name: paper.venue },
	isPartOf: { '@type': 'Periodical', name: paper.venue },
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`AI research and peer-reviewed papers · ${SITE_TITLE}`} description={description} ogImage="/og/research.png" />
		{papersLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)}
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<div class="prompt net"><span>~/kforcode</span>$ ls research/</div>
				<h1>Research</h1>
				<p>
					Peer-reviewed work at the intersection of deep learning and applied systems:
					Document AI, privacy, clinical summarization, and parameter-efficient fine-tuning.
				</p>
			</header>

			<section class="papers" aria-labelledby="papers-title">
				<h2 id="papers-title" class="net">{PAPERS.length} publications</h2>
				<ol>
					{PAPERS.map((paper, i) => (
						<li>
							<div class="paper-meta net"><span>paper_{String(i + 1).padStart(2, '0')}</span><span>{paper.year}</span></div>
							<div class="paper-body">
								<span class="venue net">{paper.venue}</span>
								<h3>{paper.title}</h3>
								<p class="authors">{paper.authors}</p>
								<p>{paper.abstract}</p>
								<div class="paper-foot">
									<div>{paper.tags.map((tag) => <span class="chip">{tag}</span>)}</div>
									<a href={paper.url} target="_blank" rel="noopener">read paper ↗</a>
								</div>
							</div>
						</li>
					))}
				</ol>
			</section>

			<section class="contact">
				<div><span class="net">research_to_production</span><h2>Interested in the implementation?</h2><p>I write about what happens after the paper: evaluation, reliability, latency, cost, and operating the system in production.</p></div>
				<a class="btn ghost" href="/blog">read the writing →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		max-width: 760px;
		padding: 2.5rem 0 3.5rem;
	}

	.prompt {
		margin-bottom: 1rem;
		text-transform: none;
	}

	.prompt span,
	.paper-meta span:first-child,
	.venue {
		color: var(--accent);
	}

	.page-head h1 {
		font-size: clamp(2.8rem, 6vw, 4.6rem);
	}

	.page-head p {
		margin: 1.1rem 0 0;
		color: var(--muted);
		font-size: 1.02rem;
	}

	.papers > h2 {
		margin-bottom: 1rem;
		color: var(--ink-soft);
	}

	.papers ol {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.papers li {
		display: grid;
		grid-template-columns: 130px minmax(0, 1fr);
		gap: 2rem;
		padding: 1.75rem 0;
		border-top: 1px solid var(--line);
	}

	.papers li:last-child {
		border-bottom: 1px solid var(--line);
	}

	.paper-meta {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding-top: 0.15rem;
		font-size: 0.63rem;
	}

	.paper-body h3 {
		margin: 0.45rem 0 0.3rem;
		font-size: 1.3rem;
	}

	.authors {
		margin: 0 0 0.8rem;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.65rem;
	}

	.paper-body > p:last-of-type {
		max-width: 720px;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.paper-foot,
	.paper-foot > div {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.paper-foot {
		justify-content: space-between;
		margin-top: 1.2rem;
	}

	.paper-foot > a {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		text-decoration: none;
	}

	.paper-foot > a:hover {
		color: var(--accent);
	}

	.contact {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		margin-top: 4rem;
		padding: 1.75rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-panel);
	}

	.contact h2 {
		margin-top: 0.5rem;
		font-size: 1.5rem;
	}

	.contact p {
		max-width: 650px;
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-size: 0.84rem;
	}

	.contact .btn {
		flex: none;
	}

	@media (max-width: 650px) {
		.page-head {
			padding-top: 1rem;
		}

		.papers li {
			grid-template-columns: 1fr;
			gap: 0.7rem;
		}

		.paper-meta {
			flex-direction: row;
			justify-content: space-between;
		}

		.contact {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
