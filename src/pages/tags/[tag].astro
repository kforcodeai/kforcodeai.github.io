---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE, TOPICS } from '../../consts';
import { byDateDesc, tagCounts } from '../../lib/utils';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return tagCounts(posts).map(({ tag }) => ({
		params: { tag },
		props: { posts: posts.filter((post) => (post.data.tags ?? []).includes(tag)).sort(byDateDesc) },
	}));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const topic = TOPICS.find((item) => item.slug === tag);
const label = topic?.label ?? `#${tag}`;
const blurb = topic?.blurb ?? `Production AI engineering notes tagged “${tag}” by Kaushal Prajapati.`;
---

<!doctype html>
<html lang="en">
	<head><BaseHead title={`${label} articles · ${SITE_TITLE}`} description={`${blurb} Browse ${posts.length} article${posts.length === 1 ? '' : 's'} in this topic.`} /></head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<a href="/blog" class="net back">← writing</a>
				<div class="prompt net"><span>~/writing</span>$ rg "{tag}"</div>
				<h1>{label}</h1>
				<p>{blurb}</p>
			</header>
			<section aria-labelledby="topic-title">
				<h2 id="topic-title" class="net">{posts.length} matching post{posts.length === 1 ? '' : 's'}</h2>
				<div class="post-list">{posts.map((post, i) => <PostCard post={post} index={i + 1} variant="row" />)}</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		max-width: 720px;
		padding: 1rem 0 3.5rem;
	}

	.back {
		display: inline-block;
		margin-bottom: 2.5rem;
		color: var(--muted);
		text-decoration: none;
	}

	.prompt {
		margin-bottom: 1rem;
		text-transform: none;
	}

	.prompt span {
		color: var(--accent);
	}

	.page-head h1 {
		font-size: clamp(2.8rem, 6vw, 4.6rem);
	}

	.page-head p {
		margin: 1rem 0 0;
		color: var(--muted);
		font-size: 1rem;
	}

	section > h2 {
		margin-bottom: 1rem;
		color: var(--ink-soft);
	}
</style>
