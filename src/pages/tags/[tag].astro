---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE, TOPICS } from '../../consts';
import { byDateDesc, tagCounts } from '../../lib/utils';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = tagCounts(posts).map((item) => item.tag);
	return tags.map((tag) => ({
		params: { tag },
		props: { posts: posts.filter((post) => (post.data.tags ?? []).includes(tag)).sort(byDateDesc) },
	}));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const topic = TOPICS.find((item) => item.slug === tag);
const label = topic?.label ?? `#${tag}`;
const blurb = topic?.blurb ?? `Production AI engineering notes tagged “${tag}” by Kaushal Prajapati.`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${label} articles · ${SITE_TITLE}`} description={`${blurb} Browse ${posts.length} article${posts.length === 1 ? '' : 's'} in this topic.`} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<div>
					<a class="net back" href="/blog">← WRITING ARCHIVE</a>
					<span class="eyebrow">TOPIC / {topic?.net ?? tag?.toUpperCase()}</span>
					<h1>{label}</h1>
					<p>{blurb}</p>
				</div>
				<span class="count" aria-label={`${posts.length} posts`}>{String(posts.length).padStart(2, '0')}</span>
			</header>

			<section class="topic-posts" aria-label={`Articles about ${label}`}>
				<h2 class="sr-only">Articles about {label}</h2>
				<div class="list-head"><span class="net">{posts.length} MATCHING NOTES</span><span class="rule"></span></div>
				<div class="posts">{posts.map((post, i) => <PostCard post={post} index={i + 1} variant="card" />)}</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding-top: 4rem;
	}

	.page-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 3rem;
		padding-bottom: 3.5rem;
		border-bottom: 2px solid var(--ink);
	}

	.back {
		display: block;
		margin-bottom: 2rem;
		color: var(--muted);
		text-decoration: none;
	}

	.back:hover {
		color: var(--accent);
	}

	.page-head h1 {
		margin: 0.8rem 0 1rem;
		font-size: clamp(4rem, 3rem + 5vw, 7rem);
	}

	.page-head p {
		max-width: 650px;
		margin: 0;
		color: var(--ink-soft);
		font-family: var(--font-editorial);
		font-size: 1.18rem;
		line-height: 1.55;
	}

	.count {
		color: var(--accent);
		font-family: var(--font-display);
		font-size: 6.5rem;
		font-weight: 750;
		line-height: 0.8;
		letter-spacing: -0.08em;
	}

	.topic-posts {
		padding-top: 4rem;
	}

	.list-head {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1.5rem;
	}

	.rule {
		height: 1px;
		background: var(--line-strong);
	}

	.posts {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 680px) {
		.page-head {
			align-items: flex-start;
			flex-direction: column;
		}

		.count {
			font-size: 4.5rem;
		}

		.posts {
			grid-template-columns: 1fr;
		}
	}
</style>
