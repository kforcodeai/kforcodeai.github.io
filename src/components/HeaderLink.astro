---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'> & { index?: string };

const { href, index, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const base = '/' + (subpath?.[0] || '');
const isActive = href === pathname || href === base;
---

<a href={href} class:list={[className, 'hlink', { active: isActive }]} {...props}>
	{index && <span>{index}</span>}
	<slot />
</a>

<style>
	.hlink {
		position: relative;
		display: inline-flex;
		align-items: baseline;
		gap: 0.32rem;
		min-height: 44px;
		padding: 0.55em 0.75em;
		color: var(--ink-soft);
		font-family: var(--font-display);
		font-size: 0.82rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		text-decoration: none;
		transition: color 0.15s var(--ease);
	}

	.hlink span {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.52rem;
		font-weight: 500;
		letter-spacing: 0;
	}

	.hlink::after {
		content: '';
		position: absolute;
		left: 0.75em;
		right: 0.75em;
		bottom: 0.18em;
		height: 2px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.2s var(--ease);
	}

	.hlink:hover,
	.hlink.active {
		color: var(--ink);
	}

	.hlink:hover::after,
	.hlink.active::after {
		transform: scaleX(1);
	}

	.hlink.active span {
		color: var(--accent);
	}

	@media (max-width: 620px) {
		.hlink {
			align-items: center;
			padding-inline: 0.48em;
			font-size: 0.74rem;
		}

		.hlink span {
			display: none;
		}
	}
</style>
