---
import FormattedDate from './FormattedDate.astro';
import { readingTime, type Post } from '../lib/utils';

interface Props {
	post: Post;
	index?: number;
	variant?: 'card' | 'row';
}

const { post, index, variant = 'card' } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const mins = readingTime(post.body);
const id = index != null ? String(index).padStart(2, '0') : undefined;
---

{
	variant === 'row' ? (
		<a href={`/blog/${post.id}/`} class="story-row">
			<span class="story-id net">{id ?? '—'}</span>
			<span class="story-copy">
				<strong>{title}</strong>
				<small>{description}</small>
			</span>
			<span class="story-meta net"><FormattedDate date={pubDate} /> · {mins} MIN</span>
			<span class="story-arrow" aria-hidden="true">↗</span>
		</a>
	) : (
		<article class="node story-card">
			<div class="card-top net">
				<span>NOTE / {id ?? '—'}</span>
				<span><FormattedDate date={pubDate} /></span>
			</div>
			<h3><a href={`/blog/${post.id}/`}>{title}</a></h3>
			<p>{description}</p>
			<div class="card-foot">
				<div class="card-tags">
					{(tags ?? []).slice(0, 3).map((tag) => <a class="chip" href={`/tags/${tag}/`}>{tag}</a>)}
				</div>
				<a class="card-read" href={`/blog/${post.id}/`} aria-label={`Read ${title}`}>{mins} min <span>↗</span></a>
			</div>
		</article>
	)
}

<style>
	.story-card {
		display: flex;
		flex-direction: column;
		min-height: 330px;
		padding: 1.5rem;
	}

	.card-top {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.card-top span:first-child {
		color: var(--accent);
	}

	.story-card h3 {
		font-size: clamp(1.45rem, 1.2rem + 1vw, 2rem);
		line-height: 1.08;
	}

	.story-card h3 a {
		color: var(--ink);
		text-decoration: none;
	}

	.story-card h3 a:hover {
		color: var(--accent);
	}

	.story-card > p {
		margin-top: 0.6rem;
		color: var(--muted);
		font-family: var(--font-editorial);
		font-size: 1rem;
		line-height: 1.52;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-foot {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-top: auto;
		padding-top: 1.5rem;
	}

	.card-tags {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
	}

	.card-read {
		flex: none;
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 650;
		letter-spacing: 0.04em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.card-read span {
		color: var(--accent);
	}

	.card-read:hover {
		color: var(--accent);
	}

	.story-row {
		display: grid;
		grid-template-columns: 46px minmax(0, 1fr) auto 20px;
		gap: 1.2rem;
		align-items: start;
		padding: 1.35rem 0;
		border-bottom: var(--edge) solid var(--line-strong);
		color: var(--ink);
		text-decoration: none;
		transition: all 0.18s var(--ease);
	}

	.story-row:hover {
		padding-left: 0.65rem;
		color: var(--accent);
		background: var(--accent-soft);
	}

	.story-id {
		padding-top: 0.2rem;
		color: var(--accent);
	}

	.story-copy {
		display: grid;
		gap: 0.28rem;
	}

	.story-copy strong {
		font-family: var(--font-display);
		font-size: 1.08rem;
		line-height: 1.25;
	}

	.story-copy small {
		max-width: 680px;
		color: var(--muted);
		font-family: var(--font-editorial);
		font-size: 0.9rem;
		line-height: 1.45;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.story-meta {
		padding-top: 0.2rem;
		white-space: nowrap;
	}

	.story-arrow {
		color: var(--accent);
	}

	@media (max-width: 640px) {
		.story-card {
			min-height: 300px;
		}

		.card-foot {
			align-items: flex-start;
			flex-direction: column;
		}

		.story-row {
			grid-template-columns: 32px minmax(0, 1fr) 18px;
			gap: 0.7rem;
		}

		.story-meta {
			grid-column: 2;
			grid-row: 2;
		}

		.story-arrow {
			grid-column: 3;
			grid-row: 1;
		}
	}
</style>
