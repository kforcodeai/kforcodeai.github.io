---
import FormattedDate from './FormattedDate.astro';
import { readingTime, type Post } from '../lib/utils';

interface Props {
	post: Post;
	index?: number;
	variant?: 'card' | 'row';
}

const { post, index, variant = 'card' } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const mins = readingTime(post.body);
const id = index != null ? String(index).padStart(2, '0') : undefined;
---

{
	variant === 'row' ? (
		<article class="post-row">
			<div class="post-meta net">
				<span>{id ?? 'post'}</span>
				<span><FormattedDate date={pubDate} /> · {mins} min</span>
			</div>
			<div class="post-copy">
				<h3><a href={`/blog/${post.id}/`}>{title}</a></h3>
				<p>{description}</p>
			</div>
			<a class="arrow" href={`/blog/${post.id}/`} aria-label={`Read ${title}`}>→</a>
		</article>
	) : (
		<article class="post-card">
			<div class="post-meta net">
				<span>{id ? `post_${id}` : 'post'}</span>
				<span><FormattedDate date={pubDate} /> · {mins} min</span>
			</div>
			<h3><a href={`/blog/${post.id}/`}>{title}</a></h3>
			<p>{description}</p>
			<div class="post-foot">
				<div>{(tags ?? []).slice(0, 3).map((tag) => <a class="chip" href={`/tags/${tag}/`}>{tag}</a>)}</div>
				<a href={`/blog/${post.id}/`}>read →</a>
			</div>
		</article>
	)
}

<style>
	.post-row {
		display: grid;
		grid-template-columns: 145px minmax(0, 1fr) 20px;
		gap: 1.5rem;
		padding: 1.4rem 0;
		border-top: 1px solid var(--line);
	}

	.post-row:last-child {
		border-bottom: 1px solid var(--line);
	}

	.post-meta {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding-top: 0.2rem;
		font-size: 0.63rem;
	}

	.post-meta span:first-child {
		color: var(--accent);
	}

	.post-copy h3,
	.post-card h3 {
		font-size: 1.18rem;
		line-height: 1.3;
		letter-spacing: -0.02em;
	}

	.post-copy h3 a,
	.post-card h3 a {
		color: var(--ink);
		text-decoration: none;
	}

	.post-copy h3 a:hover,
	.post-card h3 a:hover {
		color: var(--accent);
	}

	.post-copy p,
	.post-card > p {
		max-width: 690px;
		margin: 0.45rem 0 0;
		color: var(--muted);
		font-size: 0.88rem;
		line-height: 1.55;
	}

	.arrow {
		padding-top: 0.1rem;
		color: var(--muted);
		font-family: var(--font-mono);
		text-decoration: none;
	}

	.post-row:hover .arrow {
		color: var(--accent);
	}

	.post-card {
		display: flex;
		flex-direction: column;
		min-height: 260px;
		padding: 1.3rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-panel);
	}

	.post-card .post-meta {
		flex-direction: row;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.post-foot {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-top: auto;
		padding-top: 1.5rem;
	}

	.post-foot > div {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
	}

	.post-foot > a {
		flex: none;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.67rem;
		text-decoration: none;
	}

	.post-foot > a:hover {
		color: var(--accent);
	}

	@media (max-width: 650px) {
		.post-row {
			grid-template-columns: minmax(0, 1fr) 20px;
			gap: 0.8rem;
		}

		.post-row .post-meta {
			grid-column: 1 / -1;
			flex-direction: row;
			justify-content: space-between;
		}

		.post-copy {
			grid-column: 1;
		}

		.arrow {
			grid-column: 2;
		}
	}
</style>
