---
import { AUTHOR, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
	<div class="utility">
		<div class="wrap utility-inner">
			<span>Independent notes on AI systems in production</span>
			<span class="utility-status"><i class="dot"></i> Staff AI/ML Engineer · HighLevel</span>
		</div>
	</div>

	<nav class="wrap main-nav" aria-label="Primary navigation">
		<a href="/" class="brand" aria-label={`${SITE_TITLE} — home`}>
			<span class="brand-mark" aria-hidden="true">K<span>/</span>C</span>
			<span class="brand-text">
				<strong>KFORCODE</strong>
				<small>by {AUTHOR.name}</small>
			</span>
		</a>

		<div class="internal-links">
			<HeaderLink href="/blog" index="01">Writing</HeaderLink>
			<HeaderLink href="/research" index="02">Research</HeaderLink>
			<HeaderLink href="/about" index="03">About</HeaderLink>
		</div>

		<div class="tail">
			<a class="social-link" href={AUTHOR.linkedin} target="_blank" rel="me noopener">LinkedIn ↗</a>
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--bg) 90%, transparent);
		backdrop-filter: saturate(1.25) blur(12px);
		-webkit-backdrop-filter: saturate(1.25) blur(12px);
		border-bottom: var(--edge) solid var(--line-strong);
	}

	.utility {
		color: var(--bg-panel);
		background: var(--ink);
		font-family: var(--font-mono);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	.utility-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 27px;
	}

	.utility-status {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: 1.35rem;
		height: 70px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.72rem;
		margin-right: auto;
		color: var(--ink);
		text-decoration: none;
	}

	.brand:hover {
		color: var(--ink);
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 47px;
		height: 39px;
		border: 2px solid var(--ink);
		font-family: var(--font-display);
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: -0.08em;
		line-height: 1;
		box-shadow: 3px 3px 0 var(--accent);
	}

	.brand-mark span {
		color: var(--accent);
	}

	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1.05;
	}

	.brand-text strong {
		font-family: var(--font-display);
		font-size: 0.98rem;
		font-weight: 750;
		letter-spacing: 0.09em;
	}

	.brand-text small {
		margin-top: 0.24rem;
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.56rem;
		letter-spacing: 0.045em;
	}

	.internal-links,
	.tail {
		display: flex;
		align-items: center;
	}

	.internal-links {
		gap: 0.1rem;
	}

	.tail {
		gap: 0.9rem;
		padding-left: 1rem;
		border-left: var(--edge) solid var(--line);
	}

	.social-link {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.social-link:hover {
		color: var(--accent);
	}

	@media (max-width: 820px) {
		.brand-text,
		.social-link {
			display: none;
		}

		.tail {
			padding-left: 0.6rem;
		}
	}

	@media (max-width: 620px) {
		.utility-inner {
			justify-content: center;
		}

		.utility-status {
			display: none;
		}

		.main-nav {
			height: 61px;
			gap: 0.55rem;
		}

		.brand-mark {
			width: 39px;
			height: 34px;
			font-size: 0.82rem;
			box-shadow: 2px 2px 0 var(--accent);
		}

		.internal-links {
			gap: 0;
		}

		.tail {
			border-left: 0;
			padding-left: 0;
		}
	}

</style>
