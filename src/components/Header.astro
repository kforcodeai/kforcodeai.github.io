---
import { AUTHOR } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
	<nav class="wrap" aria-label="Primary navigation">
		<a href="/" class="brand" aria-label="kforcode.dev — home">
			<span aria-hidden="true">~/</span>kforcode<small>.dev</small>
		</a>

		<div class="links">
			<HeaderLink href="/blog">writing</HeaderLink>
			<HeaderLink href="/research">research</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>

		<div class="actions">
			<a class="github" href={AUTHOR.github} target="_blank" rel="me noopener">github ↗</a>
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		border-bottom: 1px solid var(--line);
		background: color-mix(in srgb, var(--bg) 92%, transparent);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}

	nav {
		display: flex;
		align-items: center;
		height: 64px;
		gap: 1.5rem;
	}

	.brand {
		margin-right: auto;
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.brand span {
		color: var(--accent);
	}

	.brand small {
		color: var(--muted);
		font-size: inherit;
	}

	.brand:hover,
	.brand:hover small {
		color: var(--accent);
	}

	.links,
	.actions {
		display: flex;
		align-items: center;
	}

	.links {
		gap: 0.25rem;
	}

	.actions {
		gap: 0.8rem;
		padding-left: 1rem;
		border-left: 1px solid var(--line);
	}

	.github {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		text-decoration: none;
	}

	.github:hover {
		color: var(--accent);
	}

	@media (max-width: 680px) {
		nav {
			gap: 0.55rem;
		}

		.github {
			display: none;
		}

		.actions {
			padding-left: 0.45rem;
		}
	}

	@media (max-width: 460px) {
		.brand small {
			display: none;
		}
	}
</style>
