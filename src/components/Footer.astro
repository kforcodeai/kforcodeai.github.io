---
import { AUTHOR } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="wrap footer-grid">
		<div class="footer-callout">
			<span class="eyebrow">Keep the signal</span>
			<h2>Useful ideas.<br />No content sludge.</h2>
			<p>Follow new field notes on LinkedIn, or add the site’s RSS feed to your reader.</p>
			<div class="footer-actions">
				<a class="btn" href={AUTHOR.linkedin} target="_blank" rel="me noopener">Follow on LinkedIn ↗</a>
				<a class="btn ghost" href="/rss.xml">Subscribe via RSS</a>
			</div>
		</div>

		<div class="footer-index">
			<div class="footer-group">
				<span class="net">Read</span>
				<a href="/blog">Writing archive</a>
				<a href="/research">Research &amp; papers</a>
				<a href="/about">About Kaushal</a>
			</div>
			<div class="footer-group">
				<span class="net">Connect</span>
				<a href={AUTHOR.github} target="_blank" rel="me noopener">GitHub ↗</a>
				<a href={AUTHOR.linkedin} target="_blank" rel="me noopener">LinkedIn ↗</a>
				<a href={`mailto:${AUTHOR.email}`}>Email ↗</a>
			</div>
		</div>
	</div>

	<div class="wrap footer-base">
		<span>© {year} {AUTHOR.name}</span>
		<span>Built in public · Bengaluru, India</span>
		<span class="edition">K/C · EDITION 03</span>
	</div>
</footer>

<style>
	footer {
		margin-top: 2rem;
		padding: 4.5rem 0 1.4rem;
		border-top: 2px solid var(--ink);
		background: var(--bg-panel);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 5rem;
		align-items: end;
	}

	.footer-callout h2 {
		max-width: 620px;
		margin: 0.8rem 0 0.7rem;
		font-size: clamp(2.6rem, 1.8rem + 3vw, 4.65rem);
	}

	.footer-callout p {
		max-width: 35rem;
		color: var(--muted);
		font-size: 0.94rem;
	}

	.footer-actions {
		display: flex;
		gap: 0.7rem;
		flex-wrap: wrap;
		margin-top: 1.4rem;
	}

	.footer-index {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		padding: 1.5rem 0 0.2rem 2rem;
		border-left: var(--edge) solid var(--line-strong);
	}

	.footer-group {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.footer-group .net {
		margin-bottom: 0.4rem;
		color: var(--accent);
	}

	.footer-group a {
		color: var(--ink-soft);
		font-size: 0.84rem;
		font-weight: 550;
		text-decoration: none;
	}

	.footer-group a:hover {
		color: var(--accent);
	}

	.footer-base {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 4rem;
		padding-top: 1rem;
		border-top: var(--edge) solid var(--line);
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.61rem;
		font-weight: 550;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.edition {
		color: var(--accent);
	}

	@media (max-width: 760px) {
		footer {
			padding-top: 3.2rem;
		}

		.footer-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.footer-index {
			padding: 1.5rem 0 0;
			border-top: var(--edge) solid var(--line);
			border-left: 0;
		}

		.footer-base {
			align-items: flex-start;
			flex-direction: column;
			margin-top: 3rem;
		}
	}
</style>
