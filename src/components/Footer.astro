---
import { AUTHOR } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="wrap footer-main">
		<div>
			<a class="footer-brand" href="/"><span>~/</span>kforcode.dev</a>
			<p>Notes on production AI, agentic systems, deep learning, and software engineering.</p>
		</div>
		<nav aria-label="Footer navigation">
			<a href="/blog">writing</a>
			<a href="/research">research</a>
			<a href="/about">about</a>
			<a href="/rss.xml">rss</a>
			<a href={AUTHOR.github} target="_blank" rel="me noopener">github ↗</a>
			<a href={AUTHOR.linkedin} target="_blank" rel="me noopener">linkedin ↗</a>
		</nav>
	</div>
	<div class="wrap footer-base">
		<span>© {year} {AUTHOR.name}</span>
		<span>Built with Astro. No tracking.</span>
	</div>
</footer>

<style>
	footer {
		margin-top: 2rem;
		padding: 3rem 0 1.5rem;
		border-top: 1px solid var(--line);
	}

	.footer-main {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 3rem;
	}

	.footer-brand {
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 0.86rem;
		font-weight: 600;
		text-decoration: none;
	}

	.footer-brand span {
		color: var(--accent);
	}

	.footer-main p {
		max-width: 31rem;
		margin: 0.65rem 0 0;
		color: var(--muted);
		font-size: 0.82rem;
	}

	footer nav {
		display: flex;
		gap: 0.9rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	footer nav a {
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		text-decoration: none;
	}

	footer nav a:hover {
		color: var(--accent);
	}

	.footer-base {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.6rem;
	}

	@media (max-width: 650px) {
		.footer-main,
		.footer-base {
			flex-direction: column;
		}

		footer nav {
			justify-content: flex-start;
		}
	}
</style>
