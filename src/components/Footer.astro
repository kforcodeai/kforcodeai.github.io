---
import { AUTHOR, SITE_TITLE } from '../consts';
const year = 2026;
---

<footer>
	<div class="wrap finner">
		<div class="fcol">
			<div class="fbrand">
				<span class="dot"></span>
				<span class="net">SYSTEM ONLINE · {SITE_TITLE}</span>
			</div>
			<p class="fmeta">
				The system layer behind production AI — agent runtimes, evals, and applied LLMs.
			</p>
		</div>

		<nav class="fnav" aria-label="Footer">
			<div class="fgroup">
				<span class="net">Site</span>
				<a href="/">Home</a>
				<a href="/blog">Writing</a>
				<a href="/research">Papers</a>
				<a href="/about">About</a>
			</div>
			<div class="fgroup">
				<span class="net">Elsewhere</span>
				<a href={AUTHOR.github} target="_blank" rel="me noopener">GitHub</a>
				<a href={AUTHOR.linkedin} target="_blank" rel="me noopener">LinkedIn</a>
				<a href={`mailto:${AUTHOR.email}`}>Email</a>
				<a href="/rss.xml">RSS</a>
			</div>
		</nav>
	</div>
	<div class="wrap fbase">
		<span class="net">© {year} {AUTHOR.name}</span>
		<span class="net">BUILT WITH ASTRO · v2</span>
	</div>
</footer>

<style>
	footer {
		border-top: var(--edge) solid var(--line);
		background: var(--bg-panel);
		padding: 2.75rem 0 2rem;
		margin-top: 2rem;
	}
	.finner {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		justify-content: space-between;
	}
	.fcol {
		max-width: 26rem;
	}
	.fbrand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.6rem;
	}
	.fmeta {
		color: var(--muted);
		font-size: 0.92rem;
		margin: 0;
	}
	.fnav {
		display: flex;
		gap: 3rem;
	}
	.fgroup {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.fgroup .net {
		margin-bottom: 0.2rem;
	}
	.fgroup a {
		color: var(--ink-soft);
		text-decoration: none;
		font-size: 0.9rem;
		transition: color 0.15s var(--ease);
	}
	.fgroup a:hover {
		color: var(--accent);
	}
	.fbase {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 2.25rem;
		padding-top: 1.25rem;
		border-top: var(--edge) solid var(--line);
	}
	@media (max-width: 640px) {
		.fnav {
			gap: 2rem;
		}
		.fbase {
			flex-direction: column;
			gap: 0.5rem;
			align-items: flex-start;
		}
	}
</style>
