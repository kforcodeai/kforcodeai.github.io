---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	ogImage?: string;
	headings?: MarkdownHeading[];
	minutes?: number;
	newer?: CollectionEntry<'blog'>;
	older?: CollectionEntry<'blog'>;
	related?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, tags, ogImage, headings = [], minutes, newer, older, related = [] } = Astro.props;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<html lang="en">
	<head>
		<BaseHead title={`${title} · Kaushal Prajapati`} description={description} ogImage={ogImage} type="article" pubDate={pubDate} updatedDate={updatedDate} tags={tags} />
	</head>
	<body>
		<div class="reading-progress" aria-hidden="true"><span></span></div>
		<Header />
		<main class="article-layout">
			<article>
				<header class="article-head">
					<a class="net back" href="/blog">← writing</a>
					<div class="prompt net"><span>~/writing</span>$ cat {title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}.md</div>
					<h1>{title}</h1>
					<p class="description">{description}</p>
					<div class="meta">
						<span>{AUTHOR.name}</span><span><FormattedDate date={pubDate} /></span>{minutes && <span>{minutes} min read</span>}{updatedDate && <span>updated <FormattedDate date={updatedDate} /></span>}
					</div>
					{tags && tags.length > 0 && <div class="tags">{tags.map((tag: string) => <a class="chip" href={`/tags/${tag}/`}>{tag}</a>)}</div>}
				</header>

				<div class="prose"><slot /></div>

				<footer class="author-note">
					<span class="net">author</span>
					<p><strong>{AUTHOR.name}</strong> is a Staff AI/ML Engineer building production AI platforms and agent infrastructure.</p>
					<div><a href="/about">about →</a><a href={AUTHOR.linkedin} target="_blank" rel="me noopener">linkedin ↗</a></div>
				</footer>
			</article>

			{toc.length > 1 && (
				<aside class="toc" aria-label="Table of contents">
					<span class="net">on_this_page</span>
					<ol>{toc.map((heading) => <li class:list={[{ sub: heading.depth === 3 }]}><a href={`#${heading.slug}`}>{heading.text}</a></li>)}</ol>
				</aside>
			)}
		</main>

		{(newer || older || related.length > 0) && (
			<section class="more wrap">
				<span class="net">continue_reading</span>
				<div class="more-list">
					{older && <a href={`/blog/${older.id}/`}><small>previous</small><strong>{older.data.title}</strong><span>←</span></a>}
					{newer && <a href={`/blog/${newer.id}/`}><small>next</small><strong>{newer.data.title}</strong><span>→</span></a>}
					{related.slice(0, 2).map((post) => <a href={`/blog/${post.id}/`}><small>related</small><strong>{post.data.title}</strong><span>→</span></a>)}
				</div>
			</section>
		)}
		<Footer />

		<script is:inline>
			(function () {
				document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach(function (heading) {
					var anchor = document.createElement('a');
					anchor.href = '#' + heading.id;
					anchor.className = 'anchor';
					anchor.textContent = '#';
					anchor.setAttribute('aria-label', 'Link to this section');
					heading.appendChild(anchor);
				});
				var progress = document.querySelector('.reading-progress span');
				function update() {
					var height = document.documentElement.scrollHeight - innerHeight;
					if (progress) progress.style.width = (height > 0 ? Math.min(100, scrollY / height * 100) : 0) + '%';
				}
				update();
				addEventListener('scroll', update, { passive: true });
			})();
		</script>
	</body>
</html>

<style>
	.reading-progress {
		position: fixed;
		z-index: 100;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
	}

	.reading-progress span {
		display: block;
		width: 0;
		height: 100%;
		background: var(--accent);
	}

	.article-layout {
		display: grid;
		grid-template-columns: minmax(0, 45rem) 13rem;
		justify-content: center;
		gap: 5rem;
		align-items: start;
	}

	article {
		min-width: 0;
	}

	.back {
		display: inline-block;
		margin-bottom: 2.5rem;
		color: var(--muted);
		text-decoration: none;
	}

	.back:hover {
		color: var(--accent);
	}

	.prompt {
		margin-bottom: 1rem;
		text-transform: none;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.prompt span {
		color: var(--accent);
	}

	.article-head h1 {
		font-size: clamp(2.5rem, 5vw, 4.3rem);
		line-height: 1.06;
	}

	.description {
		margin: 1.25rem 0 0;
		color: var(--ink-soft);
		font-size: 1.1rem;
		line-height: 1.65;
	}

	.meta,
	.tags {
		display: flex;
		gap: 0.45rem 1rem;
		flex-wrap: wrap;
	}

	.meta {
		margin-top: 1.4rem;
		padding-top: 1rem;
		border-top: 1px solid var(--line);
		color: var(--muted);
		font-family: var(--font-mono);
		font-size: 0.64rem;
	}

	.meta span:first-child {
		color: var(--ink-soft);
	}

	.tags {
		margin: 0.9rem 0 3rem;
	}

	.author-note {
		margin-top: 4rem;
		padding: 1.4rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-panel);
	}

	.author-note p {
		margin: 0.5rem 0;
		color: var(--muted);
		font-size: 0.84rem;
	}

	.author-note div {
		display: flex;
		gap: 1rem;
	}

	.author-note a {
		font-family: var(--font-mono);
		font-size: 0.66rem;
	}

	.toc {
		position: sticky;
		top: 6rem;
		padding-left: 1rem;
		border-left: 1px solid var(--line);
	}

	.toc > .net {
		color: var(--ink-soft);
	}

	.toc ol {
		list-style: none;
		margin: 0.9rem 0 0;
		padding: 0;
	}

	.toc li {
		margin-bottom: 0.65rem;
	}

	.toc li.sub {
		padding-left: 0.75rem;
	}

	.toc a {
		color: var(--muted);
		font-size: 0.72rem;
		line-height: 1.35;
		text-decoration: none;
	}

	.toc a:hover {
		color: var(--accent);
	}

	.more {
		margin-top: 4rem;
	}

	.more > .net {
		color: var(--ink-soft);
	}

	.more-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.more-list a {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.35rem 1rem;
		padding: 1.1rem;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		color: var(--ink);
		text-decoration: none;
	}

	.more-list a:hover {
		border-color: var(--line-strong);
	}

	.more-list small {
		grid-column: 1 / -1;
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 0.6rem;
	}

	.more-list strong {
		font-size: 0.86rem;
		line-height: 1.4;
	}

	.more-list span {
		color: var(--muted);
		font-family: var(--font-mono);
	}

	@media (max-width: 940px) {
		.article-layout {
			grid-template-columns: minmax(0, 45rem);
		}

		.toc {
			display: none;
		}
	}

	@media (max-width: 650px) {
		.article-layout {
			padding-top: 2rem;
		}

		.more-list {
			grid-template-columns: 1fr;
		}
	}
</style>
